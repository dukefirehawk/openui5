{
	"sap.app": {
		"id": "sap.ui5.test.cardeditor.listcard.child2",
		"type": "card",
		"i18n": "../i18n/i18n.properties",
		"title": "child2",
		"subTitle": "Test Card for Parameters",
		"applicationVersion": {
			"version": "1.0.0"
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "sap-icon://accept"
		}
	},
	"sap.card": {
		"type": "List",
		"configuration": {
			"editor": "dt",
			"childCards": {
				"child2-1": {
					"title":"child2-1",
					"manifest": "./child2-1/manifest.json"
				},
				"child2-2": {
					"manifest": "./child2-2/manifest.json"
				}
			},
			"parameters": {
				"cardTitle": {
					"value": "Child Card Title Child2"
				},
				"string": {
					"value": "StringValue"
				},
				"boolean": {
					"value": false
				},
				"maxItems": {
					"value": 4
				}
			},
			"useMainDestinations": true
		},
		"header": {
			"title": "{parameters>/cardTitle/value}",
			"icon": {
				"src": "sap-icon://add-document",
				"shape": "Circle",
				"backgroundColor": ""
			}
		},
		"data": {
			"request": {
				"url": "{{mainDestinations.dest}}/Customers",
				"parameters": {
					"$select": "CustomerID, CompanyName, Country, City, Address"
				}
			},
			"path": "/value"
		},
		"content": {
			"item": {
				"title": "{CustomerID}",
				"description": "Trainer: {CompanyName}",
				"info": {
					"value": "Location: {Country} - {City} - {Address}"
				}
			},
			"maxItems": "{parameters>/maxItems/value}"
		}
	}
}