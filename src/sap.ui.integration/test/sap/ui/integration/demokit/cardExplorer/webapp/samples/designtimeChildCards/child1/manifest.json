{
	"sap.app": {
		"id": "sap.ui5.test.cardeditor.listcard.child1",
		"type": "card",
		"i18n": "../i18n/i18n.properties",
		"title": "Employees",
		"subTitle": "Test Card for Parameters",
		"applicationVersion": {
			"version": "1.0.0"
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "sap-icon://accept"
		}
	},
	"sap.card": {
		"type": "List",
		"configuration": {
			"editor": "dt",
			"childCards": {
				"Orders": {
					"manifest": "./child1-1/manifest.json"
				}
			},
			"parameters": {
				"cardTitle": {
					"value": "{{TRANSLATED_CARD_TITLE_EMPLOYEES}}"
				},
				"maxItems": {
					"value": 2
				}
			},
			"useMainDestinations": true
		},
		"header": {
			"title": "{parameters>/cardTitle/value}",
			"icon": {
				"src": "sap-icon://add-document",
				"shape": "Circle",
				"backgroundColor": ""
			}
		},
		"data": {
			"request": {
				"url": "{{mainDestinations.dest}}/Employees",
				"parameters": {
					"$select": "EmployeeID, FirstName, LastName, Country, Title, HomePhone"
				}
			},
			"path": "/value"
		},
		"content": {
			"item": {
				"title": "{EmployeeID}",
				"description": "{FirstName} {LastName}",
				"info": {
					"value": "Info: {Country} - {Title} - {HomePhone}"
				}
			},
			"maxItems": "{parameters>/maxItems/value}"
		}
	}
}