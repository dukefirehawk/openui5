{
	"_version": "1.8.0",
	"sap.app": {
		"ach": "CA-UI5-CMP",
		"applicationVersion": {
			"version": "${version}"
		},
		"description": "{{sap.app.description}}",
		"id": "appUnderTestChart",
		"i18n": "i18n/i18n.properties",
		"title": "{{sap.app.title}}",
		"type": "application",
		"dataSources": {}
	},
	"sap.ui": {
		"deviceTypes": {
			"desktop": true,
			"phone": true,
			"tablet": true
		},
		"technology": "UI5"
	},
	"sap.ui5": {
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"dependencies": {
			"minUI5Version": "1.61",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.ui.fl": {},
				"sap.ui.mdc": {}
			}
		},
		"handleValidation": true,
		"models": {},

		"rootView": {
			"type": "XML",
			"viewName": "view.Main",
			"id": "IDViewOfAppUnderTestChart",
			"async": true
		}
	}
